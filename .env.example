# Copy this file to ".env" and fill in real values for your local environment.
# Never commit the ".env" file itself (already gitignored).

DB_NAME=awb_nettrace
DB_USERNAME=awb_dev
DB_PASSWORD=change-me

SSL_KEYSTORE_PASSWORD=change-me
APP_SECURITY_JWT_SECRET=change-me-min-32-chars-long-random-string
# Password shared by the 7 demo accounts (one per role) created on first startup.
APP_SECURITY_DEMO_USERS_PASSWORD=change-me
