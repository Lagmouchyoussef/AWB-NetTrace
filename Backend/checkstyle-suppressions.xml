<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <!-- Internal application, not a published library: Javadoc-on-everything adds noise
         without value here. Real style/complexity checks (imports, formatting, etc.) still apply. -->
    <suppress checks="MissingJavadocType|MissingJavadocMethod|MissingJavadocPackage" files=".*"/>
</suppressions>
